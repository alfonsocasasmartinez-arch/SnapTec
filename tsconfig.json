import express from 'express';
import { createServer as createViteServer } from 'vite';
import Database from 'better-sqlite3';
import multer from 'multer';
import path from 'path';
import fs from 'fs';
import { fileURLToPath } from 'url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const uploadsDir = path.join(__dirname, 'uploads');

if (!fs.existsSync(uploadsDir)) {
  fs.mkdirSync(uploadsDir);
}

const db = new Database('snaptec.db');

// Initialize database
db.exec(`
  CREATE TABLE IF NOT EXISTS projects (
    id TEXT PRIMARY KEY,
    name TEXT NOT NULL
  );

  CREATE TABLE IF NOT EXISTS phases (
    id TEXT PRIMARY KEY,
    projectId TEXT NOT NULL,
    name TEXT NOT NULL,
    FOREIGN KEY (projectId) REFERENCES projects(id) ON DELETE CASCADE
  );

  CREATE TABLE IF NOT EXISTS zones (
    id TEXT PRIMARY KEY,
    projectId TEXT NOT NULL,
    name TEXT NOT NULL,
    FOREIGN KEY (projectId) REFERENCES projects(id) ON DELETE CASCADE
  );

  CREATE TABLE IF NOT EXISTS photos (
    id TEXT PRIMARY KEY,
    filename TEXT NOT NULL,
    projectId TEXT NOT NULL,
    phase TEXT NOT NULL,
    zone TEXT NOT NULL,
    tags TEXT NOT NULL,
    timestamp INTEGER NOT NULL,
    FOREIGN KEY (projectId) REFERENCES projects(id) ON DELETE CASCADE
  );
`);

// Seed initial data if empty
const projectCount = db.prepare('SELECT count(*) as count FROM projects').get() as { count: number };
if (projectCount.count === 0) {
  const insertProject = db.prepare('INSERT INTO projects (id, name) VALUES (?, ?)');
  const insertPhase = db.prepare('INSERT INTO phases (id, projectId, name) VALUES (?, ?, ?)');
  const insertZone = db.prepare('INSERT INTO zones (id, projectId, name) VALUES (?, ?, ?)');

  insertProject.run('1', 'Proyecto 1');
  insertPhase.run('p1', '1', 'Fase 1');
  insertPhase.run('p2', '1', 'Fase 2');
  insertPhase.run('p3', '1', 'Fase 3');
  insertZone.run('z1', '1', 'Zona 1');
  insertZone.run('z2', '1', 'Zona 2');
  insertZone.run('z3', '1', 'Zona 3');

  insertProject.run('2', 'Proyecto 2');
  insertProject.run('3', 'Proyecto 3');
}

const app = express();
app.use(express.json({ limit: '50mb' }));

// Multer config
const storage = multer.diskStorage({
  destination: (req, file, cb) => {
    cb(null, uploadsDir);
  },
  filename: (req, file, cb) => {
    const uniqueSuffix = Date.now() + '-' + Math.round(Math.random() * 1e9);
    cb(null, uniqueSuffix + path.extname(file.originalname));
  }
});
const upload = multer({ storage });

// API Routes
app.get('/api/projects', (req, res) => {
  const projects = db.prepare('SELECT * FROM projects').all();
  const projectsWithDetails = projects.map((p: any) => {
    const phases = db.prepare('SELECT name FROM phases WHERE projectId = ?').all(p.id).map((ph: any) => ph.name);
    const zones = db.prepare('SELECT name FROM zones WHERE projectId = ?').all(p.id).map((z: any) => z.name);
    return { ...p, phases, zones };
  });
  res.json(projectsWithDetails);
});

app.post('/api/projects', (req, res) => {
  const { id, name } = req.body;
  db.prepare('INSERT INTO projects (id, name) VALUES (?, ?)').run(id, name);
  db.prepare('INSERT INTO phases (id, projectId, name) VALUES (?, ?, ?)').run(Date.now() + '-p', id, 'Fase 1');
  db.prepare('INSERT INTO zones (id, projectId, name) VALUES (?, ?, ?)').run(Date.now() + '-z', id, 'Zona 1');
  res.json({ success: true });
});

app.delete('/api/projects/:id', (req, res) => {
  db.prepare('DELETE FROM projects WHERE id = ?').run(req.params.id);
  res.json({ success: true });
});

app.post('/api/projects/:id/phases', (req, res) => {
  const { name } = req.body;
  db.prepare('INSERT INTO phases (id, projectId, name) VALUES (?, ?, ?)').run(Date.now().toString(), req.params.id, name);
  res.json({ success: true });
});

app.post('/api/projects/:id/zones', (req, res) => {
  const { name } = req.body;
  db.prepare('INSERT INTO zones (id, projectId, name) VALUES (?, ?, ?)').run(Date.now().toString(), req.params.id, name);
  res.json({ success: true });
});

app.get('/api/photos', (req, res) => {
  const photos = db.prepare('SELECT * FROM photos ORDER BY timestamp DESC').all();
  const formattedPhotos = photos.map((p: any) => ({
    ...p,
    url: `/uploads/${p.filename}`,
    tags: JSON.parse(p.tags)
  }));
  res.json(formattedPhotos);
});

app.post('/api/photos', upload.single('photo'), (req, res) => {
  const { projectId, phase, zone, tags } = req.body;
  const filename = req.file?.filename;
  if (!filename) return res.status(400).json({ error: 'No photo uploaded' });

  const id = Date.now().toString();
  db.prepare('INSERT INTO photos (id, filename, projectId, phase, zone, tags, timestamp) VALUES (?, ?, ?, ?, ?, ?, ?)')
    .run(id, filename, projectId, phase, zone, tags, Date.now());

  res.json({ success: true });
});

app.delete('/api/photos/:id', (req, res) => {
  const photo = db.prepare('SELECT filename FROM photos WHERE id = ?').get() as { filename: string };
  if (photo) {
    const filePath = path.join(uploadsDir, photo.filename);
    if (fs.existsSync(filePath)) fs.unlinkSync(filePath);
    db.prepare('DELETE FROM photos WHERE id = ?').run(req.params.id);
  }
  res.json({ success: true });
});

// Serve uploads
app.use('/uploads', express.static(uploadsDir));

// Vite middleware
if (process.env.NODE_ENV !== 'production') {
  const vite = await createViteServer({
    server: { middlewareMode: true },
    appType: 'spa',
  });
  app.use(vite.middlewares);
} else {
  app.use(express.static('dist'));
  app.get('*', (req, res) => res.sendFile(path.join(__dirname, 'dist/index.html')));
}

const PORT = 3000;
app.listen(PORT, '0.0.0.0', () => {
  console.log(`Server running on http://0.0.0.0:${PORT}`);
});
